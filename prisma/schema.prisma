generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DOCTOR
  PATIENT
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum InvoiceStatus {
  UNPAID
  PAID
  OVERDUE
}

enum LabStatus {
  PENDING
  COMPLETED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(PATIENT)
  image     String?
  specialty String?
  phone     String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointmentsAsPatient Appointment[]   @relation("PatientAppointments")
  appointmentsAsDoctor  Appointment[]   @relation("DoctorAppointments")
  medicalRecords        MedicalRecord[] @relation("PatientRecords")
  recordsCreated        MedicalRecord[] @relation("DoctorRecords")
  invoicesAsPatient     Invoice[]       @relation("PatientInvoices")
  invoicesAsDoctor      Invoice[]       @relation("DoctorInvoices")
  labResultsAsPatient   LabResult[]     @relation("PatientLabResults")
  labResultsAsDoctor    LabResult[]     @relation("DoctorLabResults")
  availability          DoctorAvailability[]

  accounts Account[]
  sessions Session[]
}

model Appointment {
  id        String            @id @default(cuid())
  date      DateTime
  time      String
  status    AppointmentStatus @default(PENDING)
  reason    String?
  notes     String?
  meetLink  String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  patientId String
  doctorId  String
  patient   User @relation("PatientAppointments", fields: [patientId], references: [id])
  doctor    User @relation("DoctorAppointments",  fields: [doctorId],  references: [id])

  medicalRecord MedicalRecord?
  invoice       Invoice?
}

model MedicalRecord {
  id            String   @id @default(cuid())
  diagnosis     String
  prescription  String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  patientId     String
  doctorId      String
  appointmentId String?  @unique

  patient     User         @relation("PatientRecords", fields: [patientId], references: [id])
  doctor      User         @relation("DoctorRecords",  fields: [doctorId],  references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
}

model Invoice {
  id            String        @id @default(cuid())
  amount        Float
  status        InvoiceStatus @default(UNPAID)
  description   String?
  dueDate       DateTime?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  patientId     String
  doctorId      String
  appointmentId String?  @unique

  patient     User         @relation("PatientInvoices", fields: [patientId], references: [id])
  doctor      User         @relation("DoctorInvoices",  fields: [doctorId],  references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
}

model LabResult {
  id          String    @id @default(cuid())
  testName    String
  result      String?
  fileUrl     String?
  notes       String?
  status      LabStatus @default(PENDING)
  orderedAt   DateTime  @default(now())
  completedAt DateTime?

  patientId String
  doctorId  String
  patient   User @relation("PatientLabResults", fields: [patientId], references: [id])
  doctor    User @relation("DoctorLabResults",  fields: [doctorId],  references: [id])
}

model DoctorAvailability {
  id        String   @id @default(cuid())
  doctorId  String
  dayOfWeek Int      // 0=Sun, 1=Mon ... 6=Sat
  startTime String   // "09:00"
  endTime   String   // "17:00"
  isActive  Boolean  @default(true)

  doctor User @relation(fields: [doctorId], references: [id])

  @@unique([doctorId, dayOfWeek])
}

// NextAuth required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
